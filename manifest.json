{
  "manifest_version": 3,
  "name": "TikTok Skipper",
  "version": "1.0.1",
  "description": "TikTokのWeb上で、再生中の動画を1秒送り・1秒戻しできます。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tiktok.com/*",
        "https://tiktok.com/*",
        "https://m.tiktok.com/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
